    hdrs = [
        "tiny_skia/Lib.h",
        "tiny_skia/AlphaRuns.h",
    ],
    defines = ["TINYSKIA_CPP_BIT_EXACT_MODE=1"],
    visibility = ["//visibility:public"],
    include_prefix = "tiny_skia",
    strip_include_prefix = "tiny_skia",
)
